{
  "manifest_version": 3,
  "name": "Network Error Live Monitor",
  "description": "Capture 4xx/5xx network responses and inspect JSON error payloads in real time.",
  "version": "1.0.0",
  "permissions": ["webRequest", "storage", "activeTab", "sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Open Network Error Panel"
  }
}
