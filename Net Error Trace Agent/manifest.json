{
  "manifest_version": 3,
  "name": "Network Error Live Monitor",
  "description": "Capture network requests and inspect payloads in real time via DevTools panel.",
  "version": "2.0.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools.html",
  "action": {
    "default_title": "Open Network Error DevTools Panel"
  },
  "web_accessible_resources": [
    {
      "resources": ["mcp-servers.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
